{
  "name": "mute-tab-manager",
  "version": "0.5.0",
  "private": true,
  "description": "Mute/unmute tabs across Chrome and Firefox with proper YouTube support.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && wxt build -b firefox",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip && wxt zip -b firefox",
    "typecheck": "tsgo --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "generate-key": "bun run scripts/generate-key.ts",
    "generate-icons": "bun run scripts/generate-icons.ts",
    "release": "bun run scripts/release.ts",
    "changeset": "changeset",
    "changeset-add": "bun run scripts/add-changeset.ts",
    "version": "changeset version",
    "postinstall": "wxt prepare",
    "prepare": "lefthook install"
  },
  "dependencies": {},
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260621.1",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "ultracite": "7.8.3",
    "wxt": "^0.20.26"
  },
  "packageManager": "bun@1.3.14"
}
