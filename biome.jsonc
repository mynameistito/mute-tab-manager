{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "javascript": {
    "globals": ["chrome"]
  },
  "overrides": [
    {
      "includes": ["scripts/**", "apps/*/scripts/**"],
      "javascript": {
        "globals": ["Bun"]
      }
    },
    {
      "includes": ["apps/*/__tests__/**", "packages/*/__tests__/**"],
      "javascript": {
        "globals": ["Bun", "chrome"]
      }
    }
  ]
}
